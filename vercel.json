{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/push-cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/push-favorites-cron",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/keep-alive",
